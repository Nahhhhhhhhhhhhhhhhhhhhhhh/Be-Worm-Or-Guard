-- // 5. THE ENGINES (THE "MISSING" SCRIPTS)

-- FOV Drawing Setup
local FOVCircle = Drawing.new("Circle")
FOVCircle.Thickness = 2
FOVCircle.NumSides = 64
FOVCircle.Filled = false
FOVCircle.Transparency = 1

-- Target Validation Logic
local function IsValid(obj)
    if not obj:FindFirstChild("Humanoid") or obj.Humanoid.Health <= 0 then return false end
    local name = obj.Name:lower()
    
    local targetingAll = false
    for _, t in pairs(States.TargetTeams) do if t == "All" then targetingAll = true break end end
    if targetingAll then return true end
    
    for _, team in pairs(States.TargetTeams) do
        if name:find(team:lower()) then return true end
    end
    return false
end

-- Get Closest Target to Center
local function GetTarget()
    local target = nil
    local dist = math.huge
    local center = game.Workspace.CurrentCamera.ViewportSize / 2

    local list = {}
    for _, p in pairs(game.Players:GetPlayers()) do
        if p ~= game.Players.LocalPlayer and p.Character then table.insert(list, p.Character) end
    end
    for _, o in pairs(game.Workspace:GetChildren()) do
        if o:IsA("Model") and o:FindFirstChild("Humanoid") and not game.Players:GetPlayerFromCharacter(o) then
            table.insert(list, o)
        end
    end

    for _, char in pairs(list) do
        if IsValid(char) then
            local head = char:FindFirstChild("Head")
            if head then
                local pos, onScreen = game.Workspace.CurrentCamera:WorldToViewportPoint(head.Position)
                if onScreen then
                    local screenDist = (Vector2.new(pos.X, pos.Y) - center).Magnitude
                    local worldDist = (game.Players.LocalPlayer.Character.HumanoidRootPart.Position - head.Position).Magnitude
                    
                    if screenDist <= States.FOVRadius and worldDist <= States.MaxDist then
                        if screenDist < dist then
                            dist = screenDist
                            target = head
                        end
                    end
                end
            end
        end
    end
    return target
end

-- // 6. MAIN RENDER LOOP
game:GetService("RunService").RenderStepped:Connect(function()
    -- Circle Update
    FOVCircle.Visible = States.FOVVisible
    FOVCircle.Radius = States.FOVRadius
    FOVCircle.Color = States.FOVColor
    FOVCircle.Position = game.Workspace.CurrentCamera.ViewportSize / 2

    -- Aimbot Execution
    if States.Aimbot then
        local lock = GetTarget()
        if lock then
            game.Workspace.CurrentCamera.CFrame = CFrame.new(game.Workspace.CurrentCamera.CFrame.Position, lock.Position)
        end
    end

    -- ESP Execution
    if States.ESP then
        for _, o in pairs(game.Workspace:GetChildren()) do
            if o:IsA("Model") and o:FindFirstChild("Humanoid") and o ~= game.Players.LocalPlayer.Character then
                if IsValid(o) then
                    local h = o:FindFirstChild("EliteESP") or Instance.new("Highlight", o)
                    h.Name = "EliteESP"
                    h.Enabled = true
                    
                    -- Color logic based on name
                    local n = o.Name:lower()
                    h.FillColor = n:find("worm") and Color3.fromRGB(255,0,0) or n:find("guard") and Color3.fromRGB(0,150,255) or Color3.fromRGB(255,200,0)
                elseif o:FindFirstChild("EliteESP") then
                    o.EliteESP.Enabled = false
                end
            end
        end
    end
end)

Rayfield:Notify({Title = "BWOG HUB", Content = "Script fully loaded and fixed!", Duration = 5})
