--[[
    BE WORM OR GUARD | ULTIMATE TARGETING HUB
    Fixed: Team Dropdown, Centered FOV, Distance Slider, and Color Picker
]]

local Rayfield = loadstring(game:HttpGet('https://sirius.menu/rayfield'))()

-- // 1. GLOBAL SETTINGS
local Window = Rayfield:CreateWindow({
   Name = "Zen Hub| BE WORM OR GUARD",
   LoadingTitle = "Configuring Modules...",
   ConfigurationSaving = { Enabled = true, FolderName = "BWOG_Final_v2" }
})

-- State Variables
local AimbotEnabled, FOVVisible = false, true
local MaxDistance, FOVRadius = 300, 100
local AimPart = "Head"
local FOVColor = Color3.fromRGB(255, 255, 255)
local TargetTeams = {"Worm", "Guard", "Special Force"} -- Default targets

-- // 2. UI TABS
local CombatTab = Window:CreateTab("Combat", 4483362458)

-- // 3. COMBAT CONFIGURATION
CombatTab:CreateSection("Aimbot Master")

CombatTab:CreateToggle({
   Name = "Enable Aimbot",
   CurrentValue = false,
   Callback = function(Value) AimbotEnabled = Value end,
})

CombatTab:CreateDropdown({
   Name = "Target Teams",
   Options = {"Worm", "Guard", "Special Force", "All"},
   CurrentValue = {"All"},
   MultiSelection = true, -- Allows you to pick multiple teams to aim at
   Callback = function(Options)
      TargetTeams = Options
   end,
})

CombatTab:CreateSlider({
   Name = "Aimbot Activation Range",
   Range = {10, 2000},
   Increment = 10,
   CurrentValue = 300,
   Suffix = " Studs",
   Callback = function(Value) MaxDistance = Value end,
})

CombatTab:CreateSection("FOV Customization")

CombatTab:CreateToggle({
   Name = "Show FOV Circle",
   CurrentValue = true,
   Callback = function(Value) FOVVisible = Value end,
})

CombatTab:CreateSlider({
   Name = "FOV Radius",
   Range = {30, 600},
   Increment = 5,
   CurrentValue = 100,
   Callback = function(Value) FOVRadius = Value end,
})

CombatTab:CreateColorPicker({
    Name = "FOV Circle Color",
    TargetColor = FOVColor,
    Callback = function(Color) FOVColor = Color end,
})

-- // 4. THE TARGETING ENGINE

local Circle = Drawing.new("Circle")
Circle.Thickness = 2
Circle.NumSides = 64
Circle.Transparency = 1
Circle.Filled = false

local function IsTargetValid(model)
    local name = model.Name:lower()
    local isAll = false
    for _, t in pairs(TargetTeams) do if t == "All" then isAll = true break end end
    
    if isAll then return true end
    
    for _, team in pairs(TargetTeams) do
        if name:find(team:lower()) then
            return true
        end
    end
    return false
end

local function GetClosestTarget()
    local Target = nil
    local ShortestDistance = math.huge
    local Center = game.Workspace.CurrentCamera.ViewportSize / 2

    -- Scan both Players and Workspace Bots
    local Entities = {}
    for _, p in pairs(game.Players:GetPlayers()) do
        if p ~= game.Players.LocalPlayer and p.Character then table.insert(Entities, p.Character) end
    end
    for _, obj in pairs(game.Workspace:GetChildren()) do
        if obj:IsA("Model") and obj:FindFirstChild("Humanoid") and not game.Players:GetPlayerFromCharacter(obj) then
            table.insert(Entities, obj)
        end
    end

    for _, char in pairs(Entities) do
        if IsTargetValid(char) then
            local part = char:FindFirstChild(AimPart)
            if part then
                local Pos, OnScreen = game.Workspace.CurrentCamera:WorldToViewportPoint(part.Position)
                if OnScreen then
                    local ScreenDist = (Vector2.new(Pos.X, Pos.Y) - Center).Magnitude
                    local WorldDist = (game.Players.LocalPlayer.Character.HumanoidRootPart.Position - part.Position).Magnitude
                    
                    if ScreenDist < FOVRadius and WorldDist < MaxDistance then
                        if ScreenDist < ShortestDistance then
                            ShortestDistance = ScreenDist
                            Target = part
                        end
                    end
                end
            end
        end
    end
    return Target
end

-- // 5. RUNTIME LOOP
game:GetService("RunService").RenderStepped:Connect(function()
    local Center = game.Workspace.CurrentCamera.ViewportSize / 2
    Circle.Visible = FOVVisible
    Circle.Radius = FOVRadius
    Circle.Position = Center
    Circle.Color = FOVColor

    if AimbotEnabled then
        local Target = GetClosestTarget()
        if Target then
            game.Workspace.CurrentCamera.CFrame = CFrame.new(game.Workspace.CurrentCamera.CFrame.Position, Target.Position)
        end
    end
end)
